# Public analytics and conversion tracking
# Required for Google Tag Manager container injection.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Ads destination ID used by gtag.js.
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-969671559

# Public Web3Forms access key for the contact/quote forms.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_web3forms_access_key_here

# Resend API Key for email functionality
# Get your API key from https://resend.com/api-keys
# Emails will be sent from your verified domain to admin@albertonbatterymart.co.za
RESEND_API_KEY=re_your_api_key_here

# Admin credentials (for admin panel access)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
